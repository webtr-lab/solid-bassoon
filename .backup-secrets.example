# Maps Tracker Backup Secrets File
#
# WARNING: This file contains sensitive credentials!
#
# SETUP INSTRUCTIONS:
# 1. Copy this file to .backup-secrets (without .example extension)
# 2. Edit .backup-secrets and add your actual secrets
# 3. Set permissions to 600 (readable only by owner):
#    chmod 600 .backup-secrets
# 4. Add .backup-secrets to .gitignore
# 5. Do NOT commit this file to version control
#
# SECURITY NOTES:
# - This file is separate from .env to reduce exposure
# - Permissions are verified by backup scripts (they will fail if permissions are wrong)
# - Consider this a temporary solution - upgrade to HashiCorp Vault or AWS Secrets Manager for production
#

# Backup Encryption Passphrase (REQUIRED)
# This passphrase is used to encrypt all backup files with AES-256 encryption
# Generate a strong passphrase: openssl rand -base64 32
BACKUP_ENCRYPTION_PASSPHRASE=""

# Backblaze B2 Credentials (OPTIONAL)
# If B2_ENABLED=true in .env, these credentials are required
B2_ACCOUNT_ID=""
B2_APPLICATION_KEY=""

# Remote Backup SSH Key (OPTIONAL)
# Path to SSH private key for rsync remote backups
# If not set, will attempt to use default SSH key
REMOTE_BACKUP_SSH_KEY=""

# Remote Backup SSH Password (OPTIONAL - less secure than SSH key)
# Only use if SSH key is not available
REMOTE_BACKUP_SSH_PASSWORD=""
