# Server Configuration
# Replace with your server's IP address
SERVER_IP=your.server.ip.here
# Replace with your domain name (use localhost for local development)
DOMAIN=localhost

# Database Configuration
# Change these to secure values for production
POSTGRES_USER=gpsadmin
POSTGRES_PASSWORD=CHANGE_THIS_TO_A_STRONG_PASSWORD
POSTGRES_DB=gps_tracker
# Update this URL if you change the credentials above
DATABASE_URL=postgresql://gpsadmin:CHANGE_THIS_TO_A_STRONG_PASSWORD@db:5432/gps_tracker

# Flask Configuration
# Generate a secure random key with: openssl rand -hex 32
SECRET_KEY=GENERATE_RANDOM_SECRET_KEY_WITH_OPENSSL_RAND_HEX_32
FLASK_ENV=production

# CORS Configuration
# Add your frontend URLs (comma-separated, no spaces)
# For local development: http://localhost:3000,http://localhost:8080
# For production with domain: https://your-domain.com
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
