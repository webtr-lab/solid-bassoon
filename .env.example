# Server Configuration
# Replace with your server's IP address
SERVER_IP=your.server.ip.here
# Replace with your domain name (use localhost for local development)
DOMAIN=localhost

# Database Configuration
# Change these to secure values for production
POSTGRES_USER=mapsadmin
POSTGRES_PASSWORD=CHANGE_THIS_TO_A_STRONG_PASSWORD
POSTGRES_DB=maps_tracker
# Update this URL if you change the credentials above
DATABASE_URL=postgresql://mapsadmin:CHANGE_THIS_TO_A_STRONG_PASSWORD@db:5432/maps_tracker

# Flask Configuration
# Generate a secure random key with: openssl rand -hex 32
SECRET_KEY=GENERATE_RANDOM_SECRET_KEY_WITH_OPENSSL_RAND_HEX_32
FLASK_ENV=production

# Initial Admin Password
# Password for the default admin user created on first setup
# If not set, defaults to 'admin123' (NOT RECOMMENDED for production)
# Generate a secure password with: openssl rand -base64 16
# The admin user will be forced to change this password on first login
ADMIN_PASSWORD=change_this_secure_password

# Sentry Error Monitoring (optional)
# Get your DSN from https://sentry.io after creating a project
# Leave blank to disable error monitoring
SENTRY_DSN=
# Application version for release tracking
APP_VERSION=1.0.0

# CORS Configuration
# Add your frontend URLs (comma-separated, no spaces)
# For local development: http://localhost:3000,http://localhost:8080
# For production with domain: https://your-domain.com
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Nominatim Geocoding Service
# Use local instance (recommended for no rate limits) or public API
# Local: http://nominatim:8080 (via Docker network)
# Public: https://nominatim.openstreetmap.org (has rate limits)
NOMINATIM_URL=http://nominatim:8080

# SMTP Email Configuration
# Required for password reset, registration confirmation, and system alerts
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=notifications@example.com
SMTP_PASS=your-smtp-password
# Optional: Delay between consecutive emails (default: 15 seconds)
# Increase if your SMTP server rate-limits email sending
SMTP_DELAY=15
# Admin email for BCC on user registration confirmations
ADMIN_EMAIL=admin@example.com

# Frontend URL for email links (password reset, login links)
# For development: http://localhost:3000
# For production: https://your-domain.com
FRONTEND_URL=http://localhost:3000

# Backup and Maintenance Notifications
# Email address for backup status, restore test results, and system alerts
BACKUP_EMAIL=admin@example.com
# Enable/disable email notifications (true/false)
BACKUP_EMAIL_ENABLED=true

# Backup Encryption Settings
# Enable/disable AES-256 encryption for backups (true/false)
BACKUP_ENCRYPTION_ENABLED=true
# Passphrase for encrypting backups (IMPORTANT: store securely, not in version control)
# Generate with: openssl rand -base64 32
# This is critical for decryption - store in a secure location
BACKUP_ENCRYPTION_PASSPHRASE=GENERATE_SECURE_PASSPHRASE_AND_STORE_SEPARATELY

# Cloud Backup Configuration (Backblaze B2)
# Enable/disable cloud backups to Backblaze B2
B2_ENABLED=true
# Backblaze B2 Account ID (from https://secure.backblaze.com/app_keys)
B2_ACCOUNT_ID=your_backblaze_account_id
# Backblaze B2 Application Key (from https://secure.backblaze.com/app_keys)
B2_APPLICATION_KEY=your_backblaze_application_key
# B2 bucket name for storing backups
B2_BUCKET_NAME=maps-tracker-backups
# Bucket type: allPrivate (recommended) or allPublic
B2_BUCKET_TYPE=allPrivate
# Number of days to retain backups in B2 (default: 180 = 6 months)
B2_RETENTION_DAYS=180
# Enable automatic cleanup of old backups (true/false)
B2_CLEANUP_ENABLED=true

# Legacy Remote Backup Configuration (rsync - DEPRECATED)
# Use B2 configuration above instead
# REMOTE_BACKUP_ENABLED=false
# REMOTE_BACKUP_HOST=backup.example.com
# REMOTE_BACKUP_USER=backup_user
# REMOTE_BACKUP_DIR='~/maps-tracker-backup'
# REMOTE_BACKUP_SSH_PORT=22

# Redis Configuration (optional - for caching and rate limiting)
# Used by monitoring and caching services
# Default: redis://redis:6379/0 (via Docker network)
REDIS_URL=redis://redis:6379/0

# Grafana Monitoring Configuration (optional)
# Used for visualization and monitoring dashboards
# Admin credentials for Grafana web interface
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_THIS_GRAFANA_PASSWORD
# Grafana service URL (via Docker network)
GRAFANA_URL=http://grafana:3000

# Prometheus Alertmanager SMTP Configuration (for alert notifications)
# SMTP password for sending alert emails via Alertmanager
# This should match your notification email SMTP credentials
SMTP_PASSWORD=your-smtp-password-for-alerts
